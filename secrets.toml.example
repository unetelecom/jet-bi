# ═══════════════════════════════════════════════════════════════════════════════
# JET BI — CONFIGURAÇÃO DE USUÁRIOS E AUTENTICAÇÃO
# ═══════════════════════════════════════════════════════════════════════════════
#
# ESTE ARQUIVO É APENAS UM TEMPLATE — NÃO ENVIAR PRO GITHUB!
#
# Como usar:
#   1. Local: copie este conteúdo para .streamlit/secrets.toml
#   2. Streamlit Cloud: cole no painel "App settings → Secrets"
#
# Para gerar uma nova senha:
#   python -c "import streamlit_authenticator as stauth; print(stauth.Hasher(['SUA_SENHA']).generate()[0])"
#
# ═══════════════════════════════════════════════════════════════════════════════

[cookie]
name = "jet_bi_auth"
key = "TROQUE_ISSO_POR_UMA_CHAVE_LONGA_E_ALEATORIA_DE_PELO_MENOS_32_CARACTERES"
expiry_days = 7

# Cada usuário tem: nome (display name) e password (hash bcrypt)
# A senha "jet2026" tem hash: $2b$12$KIXxh.Tt8VPq6dGEKf6P5OZWvE9ChWGCkN0iU0pNQOQXR9tHE3ZJq

[users.ruan]
name = "Ruan Carlos"
password = "$2b$12$KIXxh.Tt8VPq6dGEKf6P5OZWvE9ChWGCkN0iU0pNQOQXR9tHE3ZJq"

[users.financeiro]
name = "Financeiro"
password = "$2b$12$KIXxh.Tt8VPq6dGEKf6P5OZWvE9ChWGCkN0iU0pNQOQXR9tHE3ZJq"

# Adicione mais usuários aqui conforme necessidade:
# [users.OUTRO_USUARIO]
# name = "Nome de Exibição"
# password = "$2b$12$..."
